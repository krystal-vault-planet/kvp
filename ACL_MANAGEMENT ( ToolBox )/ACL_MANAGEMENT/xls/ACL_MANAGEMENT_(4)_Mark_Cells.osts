{"version":"0.3.0","body":"function main(workbook: ExcelScript.Workbook) {\n  const cell = workbook.getActiveCell();\n\n  const markColor = \"#0070C0\";\n  const markWeight = ExcelScript.BorderWeight.thick;\n\n  if (isMarkedByDiagonalUp(cell, markColor, markWeight)) {\n    // UNMARK: remove only diagonals (keep other formatting intact)\n    clearDiagonalMarks(cell);\n  } else {\n    // MARK: apply diagonals\n    applyDiagonalMarks(cell, markColor, markWeight);\n  }\n}\n\n/**\n * Mark detection: same idea as Script 5.\n * We consider the cell marked if diagonalUp is blue + thick.\n */\nfunction isMarkedByDiagonalUp(\n  cell: ExcelScript.Range,\n  color: string,\n  weight: ExcelScript.BorderWeight\n): boolean {\n  const b = cell.getFormat().getRangeBorder(ExcelScript.BorderIndex.diagonalUp);\n  const c = (b.getColor() ?? \"\").toUpperCase();\n\n  return c === color.toUpperCase() && b.getWeight() === weight;\n}\n\n/** Apply diagonalUp + diagonalDown mark (blue + thick). */\nfunction applyDiagonalMarks(\n  cell: ExcelScript.Range,\n  color: string,\n  weight: ExcelScript.BorderWeight\n) {\n  const fmt = cell.getFormat();\n\n  // diagonalDown\n  const dDown = fmt.getRangeBorder(ExcelScript.BorderIndex.diagonalDown);\n  dDown.setStyle(ExcelScript.BorderLineStyle.continuous);\n  dDown.setWeight(weight);\n  dDown.setColor(color);\n\n  // diagonalUp\n  const dUp = fmt.getRangeBorder(ExcelScript.BorderIndex.diagonalUp);\n  dUp.setStyle(ExcelScript.BorderLineStyle.continuous);\n  dUp.setWeight(weight);\n  dUp.setColor(color);\n}\n\n/**\n * Remove ONLY diagonalUp/diagonalDown marks.\n * We set style to 'none' and leave all other borders & formatting untouched.\n */\nfunction clearDiagonalMarks(cell: ExcelScript.Range) {\n  const fmt = cell.getFormat();\n\n  const dDown = fmt.getRangeBorder(ExcelScript.BorderIndex.diagonalDown);\n  dDown.setStyle(ExcelScript.BorderLineStyle.none);\n\n  const dUp = fmt.getRangeBorder(ExcelScript.BorderIndex.diagonalUp);\n  dUp.setStyle(ExcelScript.BorderLineStyle.none);\n}","description":"","noCodeMetadata":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[],\"parameterSchema\":{\"type\":\"object\",\"default\":{},\"x-ms-visibility\":\"internal\"},\"returnSchema\":{\"type\":\"object\",\"properties\":{}},\"signature\":{\"comment\":\"\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}