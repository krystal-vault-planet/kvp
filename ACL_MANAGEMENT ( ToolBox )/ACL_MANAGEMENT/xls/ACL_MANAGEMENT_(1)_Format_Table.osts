{"version":"0.3.0","body":"function main(workbook: ExcelScript.Workbook) {\n\n  // Get the active cell and worksheet.\n  let selectedCell = workbook.getActiveCell();\n  let selectedSheet = workbook.getActiveWorksheet();\n\n  // Insert new column as A:A for \"SAFE_PREFIX\" formulas and copy data from B:B for ExtendedRange purpose.\n  selectedSheet.getRange(\"A:A\").insert(ExcelScript.InsertShiftDirection.right);\n  selectedSheet.getRange(\"A:A\").copyFrom(selectedSheet.getRange(\"B:B\"));\n  selectedSheet.getRange(\"A1\").setValue(\"SAFE_PREFIX\");\n\n  // Insert new column as B:B for \"MEMBER_PREFIX\" formulas and copy data from C:C for ExtendedRange purpose.\n  selectedSheet.getRange(\"B:B\").insert(ExcelScript.InsertShiftDirection.right);\n  selectedSheet.getRange(\"B:B\").copyFrom(selectedSheet.getRange(\"C:C\"));\n  selectedSheet.getRange(\"B1\").setValue(\"MEMBER_PREFIX\");\n\n  // Select range A2++down and insert formulas for \"SAFE_PREFIX\" filter.\n  selectedSheet.getRange(\"A2\").getExtendedRange(ExcelScript.KeyboardDirection.down).setFormula(\"=IF(ISNUMBER(FIND($H$2,C2,2)),LEFT(C2,FIND($H$2,C2,2)-1),\\\"#_N/A_#\\\")\");\n  // Select range B2++down and insert formulas for \"MEMBER_PREFIX\" filter.\n  selectedSheet.getRange(\"B2\").getExtendedRange(ExcelScript.KeyboardDirection.down).setFormula(\"=IF(UPPER(D2)=\\\"AUDITORS\\\",\\\"#_REF_#\\\",IF(ISNUMBER(FIND($I$2,D2,2)),LEFT(D2,FIND($I$2,D2,2)-1),\\\"#_N/A_#\\\"))\");\n\n  // Set font color to \"#C00000\" for range A1++down ( \"SAFE_PREFIX\" column ).\n  selectedSheet.getRange(\"A1\").getExtendedRange(ExcelScript.KeyboardDirection.down).getFormat().getFont().setColor(\"#C00000\");\n  // Set font color to \"#C00000\" for range B1++down ( \"MEMBER_PREFIX\" column ).\n  selectedSheet.getRange(\"B1\").getExtendedRange(ExcelScript.KeyboardDirection.down).getFormat().getFont().setColor(\"#C00000\");\n\n  // Set font as bold for range A1++down ( \"SAFE_PREFIX\" column ).\n  selectedSheet.getRange(\"A1\").getExtendedRange(ExcelScript.KeyboardDirection.down).getFormat().getFont().setBold(true);\n  // Set font as bold for range B1++down ( \"MEMBER_PREFIX\" column ).\n  selectedSheet.getRange(\"B1\").getExtendedRange(ExcelScript.KeyboardDirection.down).getFormat().getFont().setBold(true);\n\n  // Set font as \"Aptos Mono\" with size 8 for range F1++down ( \"ACL_ROLE\" column ).\n  selectedSheet.getRange(\"F1\").getExtendedRange(ExcelScript.KeyboardDirection.down).getFormat().getFont().setName(\"Aptos Mono\");\n  selectedSheet.getRange(\"F1\").getExtendedRange(ExcelScript.KeyboardDirection.down).getFormat().getFont().setSize(8);\n\n  // Get current table ( as A1:F1++down ).\n  let selectedTable = selectedSheet.getRange(\"A1:F1\").getExtendedRange(ExcelScript.KeyboardDirection.down);\n  // Set border for range A1:F1++down ( as selectedTable ).\n  selectedTable.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeLeft).setStyle(ExcelScript.BorderLineStyle.continuous);\n  selectedTable.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeLeft).setWeight(ExcelScript.BorderWeight.thin);\n  selectedTable.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeTop).setStyle(ExcelScript.BorderLineStyle.continuous);\n  selectedTable.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeTop).setWeight(ExcelScript.BorderWeight.thin);\n  selectedTable.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeBottom).setStyle(ExcelScript.BorderLineStyle.continuous);\n  selectedTable.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeBottom).setWeight(ExcelScript.BorderWeight.thin);\n  selectedTable.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeRight).setStyle(ExcelScript.BorderLineStyle.continuous);\n  selectedTable.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeRight).setWeight(ExcelScript.BorderWeight.thin);\n  selectedTable.getFormat().getRangeBorder(ExcelScript.BorderIndex.insideVertical).setStyle(ExcelScript.BorderLineStyle.continuous);\n  selectedTable.getFormat().getRangeBorder(ExcelScript.BorderIndex.insideVertical).setWeight(ExcelScript.BorderWeight.thin);\n  selectedTable.getFormat().getRangeBorder(ExcelScript.BorderIndex.insideHorizontal).setStyle(ExcelScript.BorderLineStyle.continuous);\n  selectedTable.getFormat().getRangeBorder(ExcelScript.BorderIndex.insideHorizontal).setWeight(ExcelScript.BorderWeight.thin);\n\n  // Toggle auto filter on selectedSheet starting from cell A1.\n  selectedSheet.getAutoFilter().apply(selectedSheet.getRange(\"A1\"));\n\n  // Set column G:G to small size.\n  selectedSheet.getRange(\"G:G\").getFormat().setColumnWidth(5);\n\n  // Add \"SAFE Delimiter\" menu box on top of column H:H.\n  selectedSheet.getRange(\"H1\").setValue(\"SAFE Delimiter\");\n  selectedSheet.getRange(\"H2\").setValue(\"-\");\n  let selectedBox1 = selectedSheet.getRange(\"H1:H2\")\n  // Set format for range H1:H2 ( as selectedBox1 )\n  selectedBox1.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeLeft).setStyle(ExcelScript.BorderLineStyle.continuous);\n  selectedBox1.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeLeft).setWeight(ExcelScript.BorderWeight.thick);\n  selectedBox1.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeTop).setStyle(ExcelScript.BorderLineStyle.continuous);\n  selectedBox1.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeTop).setWeight(ExcelScript.BorderWeight.thick);\n  selectedBox1.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeBottom).setStyle(ExcelScript.BorderLineStyle.continuous);\n  selectedBox1.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeBottom).setWeight(ExcelScript.BorderWeight.thick);\n  selectedBox1.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeRight).setStyle(ExcelScript.BorderLineStyle.continuous);\n  selectedBox1.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeRight).setWeight(ExcelScript.BorderWeight.thick);\n  selectedBox1.getFormat().getFill().setColor(\"#ffff00\");\n  selectedBox1.getFormat().setHorizontalAlignment(ExcelScript.HorizontalAlignment.center);\n  selectedBox1.getFormat().setIndentLevel(0);\n  selectedBox1.getFormat().setWrapText(true);\n  selectedBox1.getFormat().setColumnWidth(50);\n\n  // Add \"MEMBER Delimiter\" menu box on top of column I:I.\n  selectedSheet.getRange(\"I1\").setValue(\"MEMBER Delimiter\");\n  selectedSheet.getRange(\"I2\").setValue(\"_\");\n  let selectedBox2 = selectedSheet.getRange(\"I1:I2\")\n  // Set format for range I1:I2 ( as selectedBox2 )\n  selectedBox2.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeLeft).setStyle(ExcelScript.BorderLineStyle.continuous);\n  selectedBox2.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeLeft).setWeight(ExcelScript.BorderWeight.thick);\n  selectedBox2.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeTop).setStyle(ExcelScript.BorderLineStyle.continuous);\n  selectedBox2.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeTop).setWeight(ExcelScript.BorderWeight.thick);\n  selectedBox2.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeBottom).setStyle(ExcelScript.BorderLineStyle.continuous);\n  selectedBox2.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeBottom).setWeight(ExcelScript.BorderWeight.thick);\n  selectedBox2.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeRight).setStyle(ExcelScript.BorderLineStyle.continuous);\n  selectedBox2.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeRight).setWeight(ExcelScript.BorderWeight.thick);\n  selectedBox2.getFormat().getFill().setColor(\"#ffff00\");\n  selectedBox2.getFormat().setHorizontalAlignment(ExcelScript.HorizontalAlignment.center);\n  selectedBox2.getFormat().setIndentLevel(0);\n  selectedBox2.getFormat().setWrapText(true);\n  selectedBox2.getFormat().setColumnWidth(50);\n\n  // Set column J:J to small size.\n  selectedSheet.getRange(\"J:J\").getFormat().setColumnWidth(5);\n\n  // Set column headers as bold on range A1:J1 ( including the 2 menu box ).\n  selectedSheet.getRange(\"A1:J1\").getFormat().getFont().setBold(true);\n  // Auto fit the columns of range A:J ( including the 2 menu box ).\n  selectedSheet.getRange(\"A:J\").getFormat().autofitColumns();\n\n  // Insert shape Info_Box_1\n  let Info_Box_1 = selectedSheet.addGeometricShape(ExcelScript.GeometricShapeType.rectangle);\n  Info_Box_1.setLeft(100);\n  Info_Box_1.setTop(50);\n  Info_Box_1.setWidth(500);\n  Info_Box_1.setHeight(300);\n  Info_Box_1.getLineFormat().setColor(\"#c00000\");\n  Info_Box_1.getLineFormat().setWeight(6);\n  Info_Box_1.getFill().setForegroundColor(\"#ffc000\");\n  Info_Box_1.getTextFrame().getTextRange().getFont().setColor(\"#c00000\");\n  Info_Box_1.getTextFrame().getTextRange().getFont().setSize(40);\n  Info_Box_1.getTextFrame().setHorizontalAlignment(ExcelScript.ShapeTextHorizontalAlignment.center);\n  Info_Box_1.getTextFrame().getTextRange().setText(\"\\nDo not forget to Save As \\\"xlsx\\\" before running next script...\");\n\n  // Select cell A1 to go back on top.\n  selectedSheet.getRange(\"A1\").select();\n\n}","description":"","noCodeMetadata":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[],\"parameterSchema\":{\"type\":\"object\",\"default\":{},\"x-ms-visibility\":\"internal\"},\"returnSchema\":{\"type\":\"object\",\"properties\":{}},\"signature\":{\"comment\":\"\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}