{"version":"0.3.0","body":"function main(workbook: ExcelScript.Workbook) {\n\n  // Get the active cell and worksheet.\n  let selectedCell = workbook.getActiveCell();\n  let selectedSheet = workbook.getActiveWorksheet();\n\n  // Add a new worksheet and add pivot table on cell A5.\n  let newSheet = workbook.addWorksheet();\n  let newPivotTable = workbook.addPivotTable(\"PivotTable1\", selectedSheet.getRange(\"A1:F1\").getExtendedRange(ExcelScript.KeyboardDirection.down), newSheet.getRange(\"A5\"));\n  // Rename worksheet as \"PivTab\".\n  newSheet.setName(\"PivTab\");\n  // Switch to \"PivTab\" worksheet.\n  newSheet.activate();\n\n  // Select \"PivotTable1\" ( as pivotTable1 ).\n  let pivotTable1 = workbook.getPivotTable(\"PivotTable1\");\n  // Set filters ( above A5 ).\n  pivotTable1.addFilterHierarchy(pivotTable1.getHierarchy(\"SAFE_PREFIX\"));\n  pivotTable1.getFilterHierarchy(\"SAFE_PREFIX\").setPosition(0);\n  pivotTable1.addFilterHierarchy(pivotTable1.getHierarchy(\"MEMBER_PREFIX\"));\n  pivotTable1.getFilterHierarchy(\"MEMBER_PREFIX\").setPosition(1);\n  pivotTable1.addFilterHierarchy(pivotTable1.getHierarchy(\"memberType\"));\n  pivotTable1.getFilterHierarchy(\"memberType\").setPosition(2);\n  // Set row headers ( on left ).\n  pivotTable1.addRowHierarchy(pivotTable1.getHierarchy(\"SAFE\"));\n  // Set column headers ( on top ).\n  pivotTable1.addColumnHierarchy(pivotTable1.getHierarchy(\"MEMBER\"));\n  pivotTable1.getColumnHierarchy(\"MEMBER\").setPosition(0);\n  pivotTable1.addColumnHierarchy(pivotTable1.getHierarchy(\"ACL_ROLE\"));\n  pivotTable1.getColumnHierarchy(\"ACL_ROLE\").setPosition(1);\n  // Add data zone ( on bottom right ).\n  pivotTable1.addDataHierarchy(pivotTable1.getHierarchy(\"MEMBER\"));\n  // Set sub-total visibility of PivotTable to off.\n  pivotTable1.getLayout().setSubtotalLocation(ExcelScript.SubtotalLocationType.off);\n  // Apply sort for PivotTable on row and column fields.\n  pivotTable1.getRowHierarchy(\"SAFE\").getPivotField(\"SAFE\").sortByLabels(ExcelScript.SortBy.ascending);\n  pivotTable1.getColumnHierarchy(\"MEMBER\").getPivotField(\"MEMBER\").sortByLabels(ExcelScript.SortBy.ascending);\n  pivotTable1.getColumnHierarchy(\"ACL_ROLE\").getPivotField(\"ACL_ROLE\").sortByLabels(ExcelScript.SortBy.ascending);\n\n  // Get current tableBorderData.\n  let tableBorderData = workbook.getWorksheet(\"PivTab\").getRange(\"A7\").getExtendedRange(ExcelScript.KeyboardDirection.right).getExtendedRange(ExcelScript.KeyboardDirection.down);\n  // Set border as dot for range A7++right++down ( as tableBorderData ).\n  tableBorderData.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeLeft).setStyle(ExcelScript.BorderLineStyle.dot);\n  tableBorderData.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeLeft).setWeight(ExcelScript.BorderWeight.thin);\n  tableBorderData.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeTop).setStyle(ExcelScript.BorderLineStyle.dot);\n  tableBorderData.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeTop).setWeight(ExcelScript.BorderWeight.thin);\n  tableBorderData.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeBottom).setStyle(ExcelScript.BorderLineStyle.dot);\n  tableBorderData.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeBottom).setWeight(ExcelScript.BorderWeight.thin);\n  tableBorderData.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeRight).setStyle(ExcelScript.BorderLineStyle.dot);\n  tableBorderData.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeRight).setWeight(ExcelScript.BorderWeight.thin);\n  tableBorderData.getFormat().getRangeBorder(ExcelScript.BorderIndex.insideVertical).setStyle(ExcelScript.BorderLineStyle.dot);\n  tableBorderData.getFormat().getRangeBorder(ExcelScript.BorderIndex.insideVertical).setWeight(ExcelScript.BorderWeight.thin);\n  tableBorderData.getFormat().getRangeBorder(ExcelScript.BorderIndex.insideHorizontal).setStyle(ExcelScript.BorderLineStyle.dot);\n  tableBorderData.getFormat().getRangeBorder(ExcelScript.BorderIndex.insideHorizontal).setWeight(ExcelScript.BorderWeight.thin);\n\n  // Get current tableBorderColumns.\n  let tableBorderColumns = workbook.getWorksheet(\"PivTab\").getRange(\"A7\").getExtendedRange(ExcelScript.KeyboardDirection.right).getExtendedRange(ExcelScript.KeyboardDirection.up);\n  // Set border as continuous for range A7++right++up ( as tableBorderColumns ).\n  tableBorderColumns.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeLeft).setStyle(ExcelScript.BorderLineStyle.continuous);\n  tableBorderColumns.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeLeft).setWeight(ExcelScript.BorderWeight.thin);\n  tableBorderColumns.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeTop).setStyle(ExcelScript.BorderLineStyle.continuous);\n  tableBorderColumns.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeTop).setWeight(ExcelScript.BorderWeight.thin);\n  tableBorderColumns.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeBottom).setStyle(ExcelScript.BorderLineStyle.continuous);\n  tableBorderColumns.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeBottom).setWeight(ExcelScript.BorderWeight.thin);\n  tableBorderColumns.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeRight).setStyle(ExcelScript.BorderLineStyle.continuous);\n  tableBorderColumns.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeRight).setWeight(ExcelScript.BorderWeight.thin);\n  tableBorderColumns.getFormat().getRangeBorder(ExcelScript.BorderIndex.insideVertical).setStyle(ExcelScript.BorderLineStyle.continuous);\n  tableBorderColumns.getFormat().getRangeBorder(ExcelScript.BorderIndex.insideVertical).setWeight(ExcelScript.BorderWeight.thin);\n  tableBorderColumns.getFormat().getRangeBorder(ExcelScript.BorderIndex.insideHorizontal).setStyle(ExcelScript.BorderLineStyle.continuous);\n  tableBorderColumns.getFormat().getRangeBorder(ExcelScript.BorderIndex.insideHorizontal).setWeight(ExcelScript.BorderWeight.thin);\n\n  // Get current tableBorderRows.\n  let tableBorderRows = workbook.getWorksheet(\"PivTab\").getRange(\"A7\").getExtendedRange(ExcelScript.KeyboardDirection.down);\n  // Set border as continuous for range A7++down ( as tableBorderRows ).\n  tableBorderRows.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeLeft).setStyle(ExcelScript.BorderLineStyle.continuous);\n  tableBorderRows.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeLeft).setWeight(ExcelScript.BorderWeight.thin);\n  tableBorderRows.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeTop).setStyle(ExcelScript.BorderLineStyle.continuous);\n  tableBorderRows.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeTop).setWeight(ExcelScript.BorderWeight.thin);\n  tableBorderRows.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeBottom).setStyle(ExcelScript.BorderLineStyle.continuous);\n  tableBorderRows.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeBottom).setWeight(ExcelScript.BorderWeight.thin);\n  tableBorderRows.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeRight).setStyle(ExcelScript.BorderLineStyle.continuous);\n  tableBorderRows.getFormat().getRangeBorder(ExcelScript.BorderIndex.edgeRight).setWeight(ExcelScript.BorderWeight.thin);\n  tableBorderRows.getFormat().getRangeBorder(ExcelScript.BorderIndex.insideVertical).setStyle(ExcelScript.BorderLineStyle.continuous);\n  tableBorderRows.getFormat().getRangeBorder(ExcelScript.BorderIndex.insideVertical).setWeight(ExcelScript.BorderWeight.thin);\n  tableBorderRows.getFormat().getRangeBorder(ExcelScript.BorderIndex.insideHorizontal).setStyle(ExcelScript.BorderLineStyle.continuous);\n  tableBorderRows.getFormat().getRangeBorder(ExcelScript.BorderIndex.insideHorizontal).setWeight(ExcelScript.BorderWeight.thin);\n\n  // Set font as \"Aptos Mono\" with size 8 for range A7++right ( \"ACL_ROLE\" row ).\n  newSheet.getRange(\"A7\").getExtendedRange(ExcelScript.KeyboardDirection.right).getFormat().getFont().setName(\"Aptos Mono\");\n  newSheet.getRange(\"A7\").getExtendedRange(ExcelScript.KeyboardDirection.right).getFormat().getFont().setSize(8);\n\n  // Set the frozen range as A1:A7 on PivTab worksheet.\n  workbook.getWorksheet(\"PivTab\").getFreezePanes().freezeAt(\"A1:A7\");\n\n  // Insert shape Info_Box_2\n  let Info_Box_2 = newSheet.addGeometricShape(ExcelScript.GeometricShapeType.rectangle);\n  Info_Box_2.setLeft(100);\n  Info_Box_2.setTop(50);\n  Info_Box_2.setWidth(500);\n  Info_Box_2.setHeight(300);\n  Info_Box_2.getLineFormat().setColor(\"#c00000\");\n  Info_Box_2.getLineFormat().setWeight(6);\n  Info_Box_2.getFill().setForegroundColor(\"#ffc000\");\n  Info_Box_2.getTextFrame().getTextRange().getFont().setColor(\"#c00000\");\n  Info_Box_2.getTextFrame().getTextRange().getFont().setSize(40);\n  Info_Box_2.getTextFrame().setHorizontalAlignment(ExcelScript.ShapeTextHorizontalAlignment.center);\n  Info_Box_2.getTextFrame().getTextRange().setText(\"\\nDo not forget to add the \\\"Refresh PivTab\\\" script, as button, on top of this worksheet...\");\n\n  // Select cell D1 to insert button for refresh script.\n  workbook.getWorksheet(\"PivTab\").getRange(\"D1\").select();\n\n}","description":"","noCodeMetadata":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[],\"parameterSchema\":{\"type\":\"object\",\"default\":{},\"x-ms-visibility\":\"internal\"},\"returnSchema\":{\"type\":\"object\",\"properties\":{}},\"signature\":{\"comment\":\"\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}