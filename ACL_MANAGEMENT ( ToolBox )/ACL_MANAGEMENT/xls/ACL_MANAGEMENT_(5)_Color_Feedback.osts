{"version":"0.3.0","body":"function main(workbook: ExcelScript.Workbook) {\r\n  // ===================== CONFIG =====================\r\n  const pivotSheetName = \"PivTab\";\r\n  const sourceSheetName = workbook.getFirstWorksheet().getName();\r\n\r\n  // Pivot layout\r\n  const memberHeaderRow = 6; // MEMBER row\r\n  const roleHeaderRow = 7;   // ACL_ROLE row (also anchor A7)\r\n\r\n  // Mark definition: diagonalUp must be Blue + Thick\r\n  const markBlue = \"#0070C0\";\r\n  const markWeight = ExcelScript.BorderWeight.thick;\r\n\r\n  // Source table columns (A:F only)\r\n  const COL_SAFE = 2;   // C\r\n  const COL_MEMBER = 3; // D\r\n\r\n  // Highlight colors (only C & D)\r\n  const COLOR_YELLOW = \"#FFFF00\";\r\n  const COLOR_ORANGE = \"#FFC000\";\r\n  const COLOR_LIGHTBLUE = \"#00B0F0\";\r\n\r\n  // Sort once at end\r\n  const DO_SORT_AT_END = true;\r\n\r\n  // ---------- LOGGING FLAGS ----------\r\n  const LOG_ENABLED = true;          // master switch\r\n  const LOG_SCAN_SUMMARY = true;     // logs scan mode + scan area + estimated cells\r\n  const LOG_PROGRESS = false;         // logs progress every N rows\r\n  const LOG_EVERY_N_ROWS = 25;       // progress frequency (reduce if too chatty)\r\n  const LOG_MARK_EVENTS = false;     // logs each marked cell found (can be noisy)\r\n  const LOG_TIMING = true;           // logs timing per phase and total time\r\n  // =================== END CONFIG ===================\r\n\r\n  const t0 = Date.now();\r\n  const pvtWs = workbook.getWorksheet(pivotSheetName);\r\n  const srcWs = workbook.getWorksheet(sourceSheetName);\r\n\r\n  // ---------- Detect pivot rectangle (Ctrl+Shift style via getExtendedRange) ----------\r\n  // getExtendedRange mimics keyboard extend selection behavior. [4](https://stackoverflow.com/questions/76877043/excel-macro-error-log-line-5-cannot-read-properties-of-undefined-reading-ge)\r\n  const pivotRect = pvtWs.getRange(`A${roleHeaderRow}`)\r\n    .getExtendedRange(ExcelScript.KeyboardDirection.right)\r\n    .getExtendedRange(ExcelScript.KeyboardDirection.down);\r\n\r\n  const rectRow0 = pivotRect.getRowIndex();\r\n  const rectCol0 = pivotRect.getColumnIndex();\r\n  const rectRows = pivotRect.getRowCount();\r\n  const rectCols = pivotRect.getColumnCount();\r\n\r\n  const dataRow0 = rectRow0 + 1; // row 8\r\n  const dataCol0 = rectCol0 + 1; // col B\r\n  const lastDataRow = rectRow0 + rectRows - 1;\r\n  const lastDataCol = rectCol0 + rectCols - 1;\r\n\r\n  const memberHeaderRowIndex0 = memberHeaderRow - 1;\r\n  const roleHeaderRowIndex0 = roleHeaderRow - 1;\r\n\r\n  // ---------- Decide scan area: selection overlap with pivot body, else full body ----------\r\n  const scanBounds = getScanBoundsPreferSelection(\r\n    workbook,\r\n    pvtWs,\r\n    dataRow0, dataCol0,\r\n    lastDataRow, lastDataCol\r\n  );\r\n\r\n  if (LOG_ENABLED && LOG_SCAN_SUMMARY) {\r\n    const totalRows = scanBounds.r1 - scanBounds.r0 + 1;\r\n    const totalCols = scanBounds.c1 - scanBounds.c0 + 1;\r\n    const totalCells = totalRows * totalCols;\r\n    console.log(`[ACL5] Scan mode: ${scanBounds.usedSelection ? \"SELECTION\" : \"FULL PIVOT BODY\"}`);\r\n    console.log(`[ACL5] Scan bounds (0-based): rows ${scanBounds.r0}..${scanBounds.r1}, cols ${scanBounds.c0}..${scanBounds.c1}`);\r\n    console.log(`[ACL5] Scan size: ${totalRows} rows x ${totalCols} cols = ${totalCells} cells`);\r\n  }\r\n\r\n  // ---------- Phase 1: Build SAFE|MEMBER -> rowIndex map from source (A:F only) ----------\r\n  const t1 = Date.now();\r\n\r\n  // Use column C down to find source height (ignores helper columns beyond F).\r\n  const srcColC = srcWs.getRange(\"C1\").getExtendedRange(ExcelScript.KeyboardDirection.down); // [4](https://stackoverflow.com/questions/76877043/excel-macro-error-log-line-5-cannot-read-properties-of-undefined-reading-ge)\r\n  const srcRowCount = srcColC.getRowCount(); // includes header\r\n  const srcTableAtoF = srcWs.getRangeByIndexes(0, 0, srcRowCount, 6);\r\n  const srcVals = srcTableAtoF.getValues();\r\n\r\n  const smRow: { [k: string]: number } = {};\r\n  for (let r = 1; r < srcVals.length; r++) {\r\n    const safe = (srcVals[r][COL_SAFE] ?? \"\").toString().trim();\r\n    const member = (srcVals[r][COL_MEMBER] ?? \"\").toString().trim();\r\n    if (!safe || !member) continue;\r\n    smRow[key2(safe, member)] = r;\r\n  }\r\n\r\n  if (LOG_ENABLED && LOG_TIMING) {\r\n    console.log(`[ACL5] Phase 1 (build source map) done in ${Date.now() - t1} ms. Source rows: ${srcRowCount}`);\r\n  }\r\n\r\n  // ---------- Phase 2: Precompute MEMBER header per column (carry-forward across blanks) ----------\r\n  const t2 = Date.now();\r\n\r\n  const memberByCol: { [colIndex0: number]: string } = {};\r\n  let currentMember = \"\";\r\n  for (let c = dataCol0; c <= lastDataCol; c++) {\r\n    const txt = pvtWs.getCell(memberHeaderRowIndex0, c).getText().trim();\r\n    if (txt) currentMember = txt;\r\n    memberByCol[c] = currentMember;\r\n  }\r\n\r\n  if (LOG_ENABLED && LOG_TIMING) {\r\n    console.log(`[ACL5] Phase 2 (precompute MEMBER headers) done in ${Date.now() - t2} ms. Columns: ${lastDataCol - dataCol0 + 1}`);\r\n  }\r\n\r\n  // ---------- Phase 3: Scan pivot within chosen scan bounds ----------\r\n  const t3 = Date.now();\r\n\r\n  const insertReqs: { safe: string; member: string }[] = [];\r\n  const insertSeen: { [k: string]: boolean } = {};\r\n\r\n  let yellowHits = 0;\r\n  let orangeHits = 0;\r\n  let marksFound = 0;\r\n\r\n  const totalScanRows = scanBounds.r1 - scanBounds.r0 + 1;\r\n\r\n  for (let r = scanBounds.r0; r <= scanBounds.r1; r++) {\r\n    if (LOG_ENABLED && LOG_PROGRESS) {\r\n      const offset = r - scanBounds.r0;\r\n      if (offset % LOG_EVERY_N_ROWS === 0) {\r\n        const pct = Math.round(100 * offset / Math.max(1, totalScanRows - 1));\r\n        console.log(`[ACL5] Progress ${pct}% (row ${r}). marks=${marksFound} yellow=${yellowHits} orange=${orangeHits} inserts=${insertReqs.length}`);\r\n      }\r\n    }\r\n\r\n    const safe = pvtWs.getCell(r, rectCol0).getText().trim();\r\n    if (!safe) continue;\r\n\r\n    for (let c = scanBounds.c0; c <= scanBounds.c1; c++) {\r\n      const cell = pvtWs.getCell(r, c);\r\n\r\n      // Mark detection: diagonalUp must be blue + thick (supports manual/copy-format). [2](https://learn.microsoft.com/en-us/javascript/api/office-scripts/excelscript/excelscript.pivottable?view=office-scripts)[3](https://www.wiseowl.co.uk/office-scripts/exercises/office-scripts/refer-ranges/4723/)\r\n      if (!isMarkedDiagonalUp(cell, markBlue, markWeight)) continue;\r\n\r\n      marksFound++;\r\n\r\n      const member = (memberByCol[c] ?? \"\").trim();\r\n      if (!member || member.toLowerCase().includes(\"grand total\")) continue;\r\n\r\n      // Optional: ACL_ROLE is available if you need later\r\n      const role = pvtWs.getCell(roleHeaderRowIndex0, c).getText().trim();\r\n      if (role && role.toLowerCase().includes(\"grand total\")) continue;\r\n\r\n      const t = cell.getText().trim();\r\n      const v = t ? Number(t) : 0;\r\n\r\n      const kSM = key2(safe, member);\r\n      const existingRow = smRow[kSM];\r\n\r\n      if (LOG_ENABLED && LOG_MARK_EVENTS) {\r\n        console.log(`[ACL5] MARK @ r=${r}, c=${c} | SAFE=\"${safe}\" MEMBER=\"${member}\" ACL_ROLE=\"${role}\" val=\"${t}\"`);\r\n      }\r\n\r\n      if (v === 1) {\r\n        if (existingRow !== undefined) {\r\n          const absRow = srcTableAtoF.getRowIndex() + existingRow;\r\n          highlightCD(srcWs, absRow, COLOR_YELLOW);\r\n          yellowHits++;\r\n        }\r\n      } else {\r\n        if (existingRow !== undefined) {\r\n          const absRow = srcTableAtoF.getRowIndex() + existingRow;\r\n          highlightCD(srcWs, absRow, COLOR_ORANGE);\r\n          orangeHits++;\r\n        } else {\r\n          if (!insertSeen[kSM]) {\r\n            insertSeen[kSM] = true;\r\n            insertReqs.push({ safe, member });\r\n          }\r\n        }\r\n      }\r\n    }\r\n  }\r\n\r\n  if (LOG_ENABLED && LOG_TIMING) {\r\n    console.log(`[ACL5] Phase 3 (scan+highlight) done in ${Date.now() - t3} ms. marksFound=${marksFound}`);\r\n  }\r\n\r\n  // ---------- Phase 4: Insert missing pairs at row 2 (A:F only) ----------\r\n  const t4 = Date.now();\r\n\r\n  if (insertReqs.length > 0) {\r\n    const safeValues = insertReqs.map(x => x.safe);\r\n    const memberValues = insertReqs.map(x => x.member);\r\n    insertAtRow2_AtoF(srcWs, safeValues, memberValues, COLOR_LIGHTBLUE);\r\n  }\r\n\r\n  if (LOG_ENABLED && LOG_TIMING) {\r\n    console.log(`[ACL5] Phase 4 (insert) done in ${Date.now() - t4} ms. insertedPairs=${insertReqs.length}`);\r\n  }\r\n\r\n  // ---------- Phase 5: Sort once at end ----------\r\n  const t5 = Date.now();\r\n\r\n  if (DO_SORT_AT_END) {\r\n    // Your proven working sort pattern.\r\n    srcWs.getRange(\"A1\")\r\n      .getExtendedRange(ExcelScript.KeyboardDirection.down)\r\n      .getExtendedRange(ExcelScript.KeyboardDirection.right)\r\n      .getSort()\r\n      .apply([{ key: 2, ascending: true }, { key: 3, ascending: true }], false, true);\r\n  }\r\n\r\n  if (LOG_ENABLED && LOG_TIMING) {\r\n    console.log(`[ACL5] Phase 5 (sort) done in ${Date.now() - t5} ms`);\r\n  }\r\n\r\n  if (LOG_ENABLED) {\r\n    console.log(`[ACL5] Summary: scanMode=${scanBounds.usedSelection ? \"SELECTION\" : \"FULL\"} marks=${marksFound} yellow=${yellowHits} orange=${orangeHits} inserted=${insertReqs.length}`);\r\n  }\r\n\r\n  if (LOG_ENABLED && LOG_TIMING) {\r\n    console.log(`[ACL5] TOTAL runtime: ${Date.now() - t0} ms`);\r\n  }\r\n\r\n  return {\r\n    scanUsedSelection: scanBounds.usedSelection,\r\n    marksFound,\r\n    yellowHighlights: yellowHits,\r\n    orangeHighlights: orangeHits,\r\n    insertedPairs: insertReqs.length\r\n  };\r\n}\r\n\r\n// ==================== Helpers ====================\r\n\r\nfunction isMarkedDiagonalUp(cell: ExcelScript.Range, color: string, weight: ExcelScript.BorderWeight): boolean {\r\n  const b = cell.getFormat().getRangeBorder(ExcelScript.BorderIndex.diagonalUp);\r\n  const c = (b.getColor() ?? \"\").toUpperCase();\r\n  return c === color.toUpperCase() && b.getWeight() === weight;\r\n}\r\n\r\nfunction key2(a: string, b: string) { return a + \"\\u0001\" + b; }\r\n\r\nfunction highlightCD(ws: ExcelScript.Worksheet, rowIndex0: number, color: string) {\r\n  ws.getCell(rowIndex0, 2).getFormat().getFill().setColor(color); // C\r\n  ws.getCell(rowIndex0, 3).getFormat().getFill().setColor(color); // D\r\n}\r\n\r\nfunction insertAtRow2_AtoF(ws: ExcelScript.Worksheet, safeValues: string[], memberValues: string[], highlightColor: string) {\r\n  const n = safeValues.length;\r\n  if (n === 0) return;\r\n\r\n  const insertRange = ws.getRangeByIndexes(1, 0, n, 6); // A2:F...\r\n  insertRange.insert(ExcelScript.InsertShiftDirection.down);\r\n\r\n  const templateRow = 2 + n; // Excel 1-based row number\r\n  const template = ws.getRange(`A${templateRow}:B${templateRow}`);\r\n  const targetAB = ws.getRangeByIndexes(1, 0, n, 2);\r\n  targetAB.copyFrom(template, ExcelScript.RangeCopyType.formulas, false, false);\r\n\r\n  for (let i = 0; i < n; i++) {\r\n    const r = 1 + i; // row 2+i\r\n    ws.getCell(r, 2).setValue(safeValues[i]);    // C\r\n    ws.getCell(r, 3).setValue(memberValues[i]);  // D\r\n    ws.getCell(r, 4).clear(ExcelScript.ClearApplyTo.contents); // E empty\r\n    ws.getCell(r, 5).clear(ExcelScript.ClearApplyTo.contents); // F empty\r\n    ws.getCell(r, 2).getFormat().getFill().setColor(highlightColor);\r\n    ws.getCell(r, 3).getFormat().getFill().setColor(highlightColor);\r\n  }\r\n}\r\n\r\nfunction getScanBoundsPreferSelection(\r\n  workbook: ExcelScript.Workbook,\r\n  pivotWs: ExcelScript.Worksheet,\r\n  bodyR0: number, bodyC0: number,\r\n  bodyR1: number, bodyC1: number\r\n): { r0: number; c0: number; r1: number; c1: number; usedSelection: boolean } {\r\n\r\n  let usedSelection = false;\r\n\r\n  try {\r\n    const sel = workbook.getSelectedRange();\r\n\r\n    // If selection is a single cell, ignore it and do full scan\r\n    if (sel.getRowCount() === 1 && sel.getColumnCount() === 1) {\r\n      return { r0: bodyR0, c0: bodyC0, r1: bodyR1, c1: bodyC1, usedSelection: false };\r\n    }\r\n\r\n    // Only use selection if it is on the pivot sheet\r\n    if (sel.getWorksheet().getName() === pivotWs.getName()) {\r\n      const sr0 = sel.getRowIndex();\r\n      const sc0 = sel.getColumnIndex();\r\n      const sr1 = sr0 + sel.getRowCount() - 1;\r\n      const sc1 = sc0 + sel.getColumnCount() - 1;\r\n\r\n      // Compute overlap with pivot body bounds\r\n      const r0 = Math.max(bodyR0, sr0);\r\n      const c0 = Math.max(bodyC0, sc0);\r\n      const r1 = Math.min(bodyR1, sr1);\r\n      const c1 = Math.min(bodyC1, sc1);\r\n\r\n      if (r0 <= r1 && c0 <= c1) {\r\n        usedSelection = true;\r\n        return { r0, c0, r1, c1, usedSelection };\r\n      }\r\n    }\r\n  } catch (e) {\r\n    // selection may be invalid (pivot object, shape, multi-area). fallback below.\r\n  }\r\n\r\n  // Fallback: full pivot body\r\n  return { r0: bodyR0, c0: bodyC0, r1: bodyR1, c1: bodyC1, usedSelection: false };\r\n}","description":"","noCodeMetadata":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[],\"parameterSchema\":{\"type\":\"object\",\"default\":{},\"x-ms-visibility\":\"internal\"},\"returnSchema\":{\"type\":\"object\",\"properties\":{\"result\":{\"type\":\"object\",\"properties\":{\"scanUsedSelection\":{\"type\":\"boolean\"},\"marksFound\":{\"type\":\"number\"},\"yellowHighlights\":{\"type\":\"number\"},\"orangeHighlights\":{\"type\":\"number\"},\"insertedPairs\":{\"type\":\"number\"}}}}},\"signature\":{\"comment\":\"\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}