{"version":"0.3.0","body":"\nfunction main(workbook: ExcelScript.Workbook) {\n\n  // Switch to PivTab worksheet and select cell A1 to prevent issue when script runs from anywhere.\n  workbook.getWorksheet(\"PivTab\").activate();\n  workbook.getWorksheet(\"PivTab\").getRange(\"A1\").select();\n\n  // Get the active cell and worksheet.\n  let selectedCell = workbook.getActiveCell();\n  let selectedSheet = workbook.getActiveWorksheet();\n\n  // Set text orientation to 90 with small size for rows 6:7 on selectedSheet\n  selectedSheet.getRange(\"6:7\").getFormat().setTextOrientation(90);\n  selectedSheet.getRange(\"6:7\").getFormat().setIndentLevel(0);\n  selectedSheet.getRange(\"6:6\").getFormat().getFont().setSize(8);\n  selectedSheet.getRange(\"7:7\").getFormat().getFont().setSize(8);\n\n  // Set width of columns for range B:B++right.\n  selectedSheet.getRange(\"B:B\").getExtendedRange(ExcelScript.KeyboardDirection.right).getFormat().setColumnWidth(12);\n\n  // Get conditional formatting object.\n  let conditionalFormatting: ExcelScript.ConditionalFormat;\n  selectedSheet.getRange().clearAllConditionalFormats();\n\n  // Create cell value criteria for all cells on selectedSheet.\n  conditionalFormatting = selectedSheet.getRange().addConditionalFormat(ExcelScript.ConditionalFormatType.cellValue);\n  conditionalFormatting.getCellValue().setRule({ operator: ExcelScript.ConditionalCellValueOperator.equalTo, formula1: \"=1\" });\n  conditionalFormatting.getCellValue().getFormat().getFill().setColor(\"#ffff00\");\n  conditionalFormatting.setStopIfTrue(false);\n  conditionalFormatting.setPriority(0);\n\n  // Create Contains Text criteria for row 7:7 on selectedSheet\n  conditionalFormatting = selectedSheet.getRange(\"7:7\").addConditionalFormat(ExcelScript.ConditionalFormatType.containsText);\n  conditionalFormatting.getTextComparison().setRule({ operator: ExcelScript.ConditionalTextOperator.contains, text: \"#\" });\n  conditionalFormatting.getTextComparison().getFormat().getFont().setColor(\"#C00000\");\n  conditionalFormatting.setStopIfTrue(false);\n  conditionalFormatting.setPriority(1);\n\n  // Select cell B8 to move back to top/left data range after refresh.\n  workbook.getWorksheet(\"PivTab\").getRange(\"B8\").select();\n\n}","description":"","noCodeMetadata":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[],\"parameterSchema\":{\"type\":\"object\",\"default\":{},\"x-ms-visibility\":\"internal\"},\"returnSchema\":{\"type\":\"object\",\"properties\":{}},\"signature\":{\"comment\":\"\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}